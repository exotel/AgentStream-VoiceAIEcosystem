# Get these from https://cloud.livekit.io → your project → Settings
# LIVEKIT_URL must be your project's WebSocket URL (e.g. wss://your-project.livekit.cloud)
LIVEKIT_URL=wss://<your-project>.livekit.cloud
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>
OPENAI_API_KEY=<your OpenAI API Key>
DEEPGRAM_API_KEY=<your Deepgram API Key>
SIP_OUTBOUND_TRUNK_ID=<your SIP Outbound Trunk ID>
# Optional: worker / explicit dispatch name (default outbound-caller). Must match deployed agent.
#LIVEKIT_AGENT_NAME=outbound-caller
