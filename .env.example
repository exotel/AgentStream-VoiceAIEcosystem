# Exotel (India) - Step 1: https://my.in.exotel.com/apisettings/site#api-credentials
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_ACCOUNT_SID=
EXOTEL_SUBDOMAIN=api.in.exotel.com

# Optional display name for scripts/exotel-elevenlabs/01-create-trunk.sh
# EXOTEL_TRUNK_NAME=ElevenLabs_Trunk

# After 01-create-trunk.sh: set EXOTEL_TRUNK_SID from JSON response
EXOTEL_TRUNK_SID=

# Your purchased number from https://my.in.exotel.com/numbers (e.g. +919876543210)
EXOTEL_PHONE_NUMBER=

# Optional: for map-acl.sh (IP to allowlist; required before IP-based destination URIs)
# EXOTEL_ACL_IP=
# EXOTEL_ACL_MASK=32

# SIP digest — scripts/exotel-elevenlabs/03-credentials.sh + ElevenLabs phone import (must match)
EXOTEL_SIP_USERNAME=
EXOTEL_SIP_PASSWORD=
# EXOTEL_SIP_FRIENDLY_NAME=eleven_labs

# Optional: mapped number row id from 02-map-did.sh (for PUT mode changes)
# EXOTEL_TRUNK_PHONE_NUMBER_ID=

# ElevenLabs SIP host for Exotel destination URI (scripts/exotel-elevenlabs/04-destination-uri-elevenlabs.sh)
# ELEVENLABS_SIP_DESTINATION=sip.rtc.elevenlabs.io:5060;transport=tcp

# LiveKit - Step 3: from LiveKit Cloud Project settings
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LiveKit SIP endpoint (host only, e.g. xxxxx.sip.livekit.cloud) for Exotel destination if using FQDN
# LIVEKIT_SIP_ENDPOINT=

# Outbound calls: create outbound trunk (./livekit/scripts/create-outbound-trunk.sh or lk sip outbound create livekit/config/outbound-trunk.json), then lk sip outbound list
# SIP_OUTBOUND_TRUNK_ID=
# Agent name must match your running voice agent (e.g. voicebot)
# AGENT_NAME=voicebot
# LiveKit Cloud agent ID (for reference; use in dashboard when selecting agent for dispatch rule)
# LIVEKIT_AGENT_ID=CA_Dhp2qAHZ28EL

# Outbound via Exotel API only (no IP whitelist): scripts/exotel/outbound-call-api.sh
# EXOTEL_EXOPHONE=          # Your Exotel number (CallerId)
# EXOTEL_FLOW_APP_ID=       # App Bazaar Flow app ID (Flow that Connects to LiveKit SIP)

# ElevenLabs Voice AI Connector (elevenlabs/integrations/exotel-vsip/QUICKSTART.md)
# ELEVENLABS_API_KEY=
# ELEVENLABS_AGENT_ID=
# ELEVENLABS_AGENT_PHONE_NUMBER_ID=   # Imported Exophone ID in ElevenLabs
